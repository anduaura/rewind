{
  "defaultAction": "SCMP_ACT_ERRNO",
  "archMap": [
    { "architecture": "SCMP_ARCH_X86_64",  "subArchitectures": ["SCMP_ARCH_X86", "SCMP_ARCH_X32"] },
    { "architecture": "SCMP_ARCH_AARCH64", "subArchitectures": ["SCMP_ARCH_ARM"] }
  ],
  "syscalls": [
    {
      "comment": "eBPF — load programs, create/update maps, attach to perf events",
      "names": ["bpf", "perf_event_open", "ioctl"],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "kprobe/tracepoint attachment via perf fd",
      "names": ["perf_event_open"],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "File and directory access — /proc, /sys/kernel/debug, output .rwd files",
      "names": [
        "open", "openat", "openat2",
        "read", "readv", "pread64",
        "write", "writev", "pwrite64",
        "close", "lseek", "stat", "fstat", "lstat",
        "statx", "newfstatat",
        "access", "faccessat", "faccessat2",
        "getdents64",
        "readlink", "readlinkat",
        "mkdir", "mkdirat",
        "unlink", "unlinkat",
        "rename", "renameat", "renameat2",
        "fsync", "fdatasync", "sync_file_range",
        "dup", "dup2", "dup3",
        "fcntl", "flock",
        "truncate", "ftruncate",
        "chdir", "fchdir",
        "getcwd",
        "umask"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "Memory management",
      "names": [
        "mmap", "munmap", "mprotect", "mremap", "madvise",
        "brk", "sbrk",
        "mlock", "munlock", "mlockall", "munlockall"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "Process and thread management",
      "names": [
        "clone", "clone3", "fork", "vfork",
        "execve", "execveat",
        "wait4", "waitid", "waitpid",
        "exit", "exit_group",
        "getpid", "getppid", "gettid",
        "getuid", "geteuid", "getgid", "getegid",
        "getgroups",
        "setuid", "setgid",
        "prctl",
        "arch_prctl",
        "seccomp",
        "capget", "capset"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "Signals",
      "names": [
        "rt_sigaction", "rt_sigprocmask", "rt_sigreturn",
        "rt_sigsuspend", "rt_sigtimedwait", "rt_sigqueueinfo",
        "sigaltstack", "kill", "tkill", "tgkill"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "Sockets — Unix domain socket IPC (rewind flush) + TCP metrics server",
      "names": [
        "socket", "bind", "listen", "accept", "accept4",
        "connect", "getsockname", "getpeername",
        "setsockopt", "getsockopt",
        "sendto", "sendmsg", "sendmmsg",
        "recvfrom", "recvmsg", "recvmmsg",
        "shutdown",
        "socketpair"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "Epoll / poll / select — tokio async runtime",
      "names": [
        "epoll_create", "epoll_create1",
        "epoll_ctl", "epoll_wait", "epoll_pwait", "epoll_pwait2",
        "poll", "ppoll",
        "select", "pselect6",
        "eventfd", "eventfd2",
        "timerfd_create", "timerfd_settime", "timerfd_gettime",
        "signalfd", "signalfd4",
        "inotify_init", "inotify_init1",
        "inotify_add_watch", "inotify_rm_watch"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "Time",
      "names": [
        "clock_gettime", "clock_getres", "clock_nanosleep",
        "gettimeofday", "nanosleep", "adjtimex", "clock_adjtime"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "Resource limits — raise RLIMIT_MEMLOCK for eBPF map allocation",
      "names": ["getrlimit", "setrlimit", "prlimit64"],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "Futex — Rust/tokio threading primitives",
      "names": [
        "futex", "futex_waitv",
        "set_robust_list", "get_robust_list",
        "set_tid_address"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "Pipe — stdout/stderr plumbing",
      "names": ["pipe", "pipe2"],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "Misc runtime needs",
      "names": [
        "uname",
        "sysinfo",
        "getrandom",
        "memfd_create",
        "copy_file_range",
        "sendfile",
        "splice",
        "tee",
        "pipesize"
      ],
      "action": "SCMP_ACT_ALLOW"
    }
  ]
}
